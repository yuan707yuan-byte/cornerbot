# ============================================
# CORNER KICK PREDICTOR - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys

# Anthropic Claude API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# RapidAPI Key for API-Football (required)
# Get yours at: https://rapidapi.com/api-sports/api/api-football
# Free tier: 100 requests/day
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Custom app URL (auto-set by Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
